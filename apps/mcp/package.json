{
  "name": "mcp",
  "type": "module",
  "version": "1.0.0",
  "description": "wimad Trace MCP — read-plane MCP tools + HTTP ingest + SSE live-tail over a SQLite trace store",
  "author": "",
  "license": "MIT",
  "keywords": [
    "mcp",
    "server",
    "starter",
    "tools",
    "resources",
    "prompts",
    "uiresource",
    "ui",
    "react",
    "widgets",
    "mcp-ui",
    "apps-sdk"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "mcp-use build",
    "dev": "MCP_PORT=3011 TRACE_HTTP_PORT=3012 tsx --watch index.ts",
    "start": "MCP_PORT=3011 TRACE_HTTP_PORT=3012 tsx index.ts",
    "deploy": "mcp-use deploy",
    "postinstall": "mcp-use generate-types || true"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.0",
    "mcp-use": "latest",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
